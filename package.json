{
  "name": "bible-overlay",
  "version": "1.0.0",
  "description": "KJV Bible verse overlay for church PowerPoint presentations",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "build:win": "electron-builder --win portable --x64",
    "build:mac": "electron-builder --mac --x64"
  },
  "build": {
    "appId": "com.church.bible-overlay",
    "productName": "Bible Overlay",
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": [
        { "target": "portable", "arch": ["x64"] }
      ]
    },
    "mac": {
      "target": [
        { "target": "dmg", "arch": ["x64", "arm64"] }
      ],
      "category": "public.app-category.utilities"
    },
    "files": [
      "src/**/*"
    ]
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.0.0"
  }
}
